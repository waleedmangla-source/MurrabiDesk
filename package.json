{
  "name": "murrabi-stabilized",
  "version": "1.0.6",
  "author": "Murrabi Desk Team",
  "description": "Premium Islamic Administrative Desktop Suite",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev -p 3000",
    "launch": "node launch_desktop_stable.js",
    "preapp:dev": "lsof -i :3000 -t | xargs kill -9 || true",
    "app:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && NODE_ENV=development electron .\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron": "electron .",
    "pack": "next build && electron-builder --dir",
    "dist": "next build && electron-builder"
  },
  "build": {
    "appId": "com.murrabi.desk.v13.final",
    "productName": "Murrabi Stabilized",
    "icon": "public/icons/icon.png",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "main-sync-service.js",
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "format": "UDZO",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tiptap/extension-underline": "^3.21.0",
    "@tiptap/pm": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "clsx": "^2.1.1",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.378.0",
    "next": "14.2.3",
    "nodemailer": "^8.0.4",
    "pdf-lib": "^1.17.1",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
