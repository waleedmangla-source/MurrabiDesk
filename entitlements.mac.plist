<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow JIT compilation (V8 engine requires this) -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Allow unsigned executable memory (needed for V8) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Disable library validation (allows loading Electron's own frameworks) -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Allow dyld environment variables (needed for Electron internals) -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <!-- Network access -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>
  <!-- Allow inter-process communication (Mach ports) -->
  <key>com.apple.security.temporary-exception.mach-lookup.global-name</key>
  <array>
    <string>com.apple.distributed_notifications</string>
    <string>com.apple.coreservices.launchservices</string>
    <string>com.apple.lsd.mapdb</string>
    <string>com.apple.shm.notification-center</string>
  </array>
</dict>
</plist>

